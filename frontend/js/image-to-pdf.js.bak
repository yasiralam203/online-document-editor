// };

// add images
// imgInput.addEventListener("change", (e) => {
//     const newImages = Array.from(e.target.files);
//     images.forEach(image => {

//     //     if (isDuplicate(image)) {
//     //   return;
//     // }
//         filesArray.push(image);
//         console.log(image);
