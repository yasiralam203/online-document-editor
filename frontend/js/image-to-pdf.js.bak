imgInput.addEventListener('change', (e) => {
    const newImages = Array.from(e.target.files);

    newImages.forEach(image => {
        filesArray.push(image); // preserves order automatically
    });

    updatePreviewContainer();
    renderPreviews();
    imgInput.value = '';
    
});



/*.............
            drag and drop here.........
....................*/

// Define functions FIRST
function preventDefaults(e) {
    e.preventDefault();
    e.stopPropagation();
}

function highlight(e) {
    e.preventDefault();
    e.stopPropagation();
    uploadArea.style.backgroundColor = '#cfe0ff';
    uploadArea.style.borderColor = '#1d4ed8';
    previewContainer.classList.add('drag-over');
}

function unhighlight(e) {
    e.preventDefault();
    e.stopPropagation();
    uploadArea.style.backgroundColor = '#f0f4ff';
    uploadArea.style.borderColor = '#2563eb';
    previewContainer.classList.remove('drag-over');
}

function handleDrop(e) {
    e.preventDefault();
    e.stopPropagation();
    unhighlight(e);
    
    console.log('Drop detected'); // DEBUG
    const droppedFiles = Array.from(e.dataTransfer.files);
    console.log('Files received:', droppedFiles.length); // DEBUG
    
    // Filter for images only
    const imageFiles = droppedFiles.filter(file => file.type.startsWith('image/'));
    console.log('Image files filtered:', imageFiles.length); // DEBUG
    
    if (imageFiles.length > 0) {
        filesArray = filesArray.concat(imageFiles);
        updatePreviewContainer();
        renderPreviews();
    }
}

// NOW attach listeners
const dragZones = [uploadArea, previewContainer, imgMainSection];

dragZones.forEach(zone => {
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        zone.addEventListener(eventName, preventDefaults, false);
    });
    
    ['dragenter', 'dragover'].forEach(eventName => {
        zone.addEventListener(eventName, highlight, false);
    });
    
    ['dragleave'].forEach(eventName => {
        zone.addEventListener(eventName, unhighlight, false);
    });
    
    zone.addEventListener('drop', handleDrop, false);
});


const renderPreviews = () => {
    previewContainer.innerHTML = ''; //Clear current display

    filesArray.forEach((file, index) => {
        // Create Card Element
        const card = document.createElement('div');
        card.className = 'image-card';
        card.draggable = true;
        card.dataset.index = index;

        // Create Remove Button
        const removeBtn = document.createElement('button');
        removeBtn.className = 'remove-btn';
        removeBtn.innerHTML = '<i class="fas fa-times"></i>'; // FontAwesome Icon
        removeBtn.onclick = () => removeFile(index);

        
        // Create Image Wrapper
        const imgWrapper = document.createElement('div');
        imgWrapper.className = 'img-wrapper';

        // Read File content
        const reader = new FileReader();
        reader.onload = (e) => {
            const img = document.createElement('img');
            img.src = e.target.result;
            img.alt = file.name;
            imgWrapper.appendChild(img);
        };

        reader.readAsDataURL(file);

        // Create File Name Text
        const fileName = document.createElement('div');
        fileName.className = 'file-name';
        fileName.textContent = file.name;

        // Assemble the card
        card.appendChild(removeBtn);
        card.appendChild(imgWrapper);
        card.appendChild(fileName);

        // Add drag event listeners for desktop
        card.addEventListener('dragstart', (e) => {
            const sourceIndex = parseInt(card.dataset.index);
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/plain', sourceIndex.toString());
            card.classList.add('dragging');
            draggedIndex = sourceIndex;
            console.log('Drag started on card index:', draggedIndex);
        });

        card.addEventListener('dragend', (e) => {
            card.classList.remove('dragging');
            // Reset all cards visual state
            document.querySelectorAll('.image-card').forEach(c => {
                c.classList.remove('drag-over-card');
            });
            draggedIndex = undefined;
        });

        card.addEventListener('dragover', (e) => {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            
            const currentIndex = parseInt(card.dataset.index);
            if (draggedIndex !== currentIndex && draggedIndex !== undefined) {
                card.classList.add('drag-over-card');
            }
        });

        card.addEventListener('dragleave', (e) => {
            const currentIndex = parseInt(card.dataset.index);
            if (draggedIndex !== currentIndex) {
                card.classList.remove('drag-over-card');
            }
        });

        card.addEventListener('drop', (e) => {
            e.stopPropagation();
            e.preventDefault();
            
            const targetIndex = parseInt(card.dataset.index);
            const sourceIndex = draggedIndex;
            
            console.log('Drop on card:', targetIndex, 'from card:', sourceIndex);
            
            if (sourceIndex !== undefined && sourceIndex !== targetIndex) {
                // Swap items in array
                [filesArray[sourceIndex], filesArray[targetIndex]] = [filesArray[targetIndex], filesArray[sourceIndex]];
                draggedIndex = undefined;
                renderPreviews();
            }
        });

        // Add touch event listeners for mobile
        card.addEventListener('touchstart', (e) => {
            const sourceIndex = parseInt(card.dataset.index);
            card.classList.add('dragging');
            draggedIndex = sourceIndex;
            touchStartY = e.touches[0].clientY;
            console.log('Touch started on card index:', draggedIndex);
        });

        card.addEventListener('touchmove', (e) => {
            if (draggedIndex !== undefined) {
                e.preventDefault();
                const touch = e.touches[0];
                const element = document.elementFromPoint(touch.clientX, touch.clientY);
                
                // Find if the touch is over another card
                const targetCard = element?.closest('.image-card');
                if (targetCard) {
                    const targetIndex = parseInt(targetCard.dataset.index);
                    document.querySelectorAll('.image-card').forEach(c => {
                        c.classList.remove('drag-over-card');
                    });
                    if (targetIndex !== draggedIndex) {
                        targetCard.classList.add('drag-over-card');
                    }
                }
            }
        });

        card.addEventListener('touchend', (e) => {
            if (draggedIndex !== undefined) {
                const touch = e.changedTouches[0];
                const element = document.elementFromPoint(touch.clientX, touch.clientY);
                const targetCard = element?.closest('.image-card');
                
                if (targetCard) {
                    const targetIndex = parseInt(targetCard.dataset.index);
                    console.log('Touch drop on card:', targetIndex, 'from card:', draggedIndex);
                    
                    if (draggedIndex !== targetIndex) {
                        // Swap items in array
                        [filesArray[draggedIndex], filesArray[targetIndex]] = [filesArray[targetIndex], filesArray[draggedIndex]];
                        renderPreviews();
                    }
                }
            }
            
            // Reset all cards
            card.classList.remove('dragging');
            document.querySelectorAll('.image-card').forEach(c => {
                c.classList.remove('drag-over-card');
            });
            draggedIndex = undefined;
        });

        // Add to grid
        previewContainer.appendChild(card);
    });

    updatePreviewContainer();
};

// Track which card is being dragged
let draggedIndex = undefined;
let touchStartY = 0;

// 3. Remove Function
const removeFile = (index) => {
    // Remove file from array at specific index
    filesArray.splice(index, 1);
    // Re-render the list
    renderPreviews();

};